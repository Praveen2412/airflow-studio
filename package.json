{
  "name": "airflow-vscode",
  "displayName": "Airflow Manager",
  "description": "Manage Apache Airflow and AWS MWAA environments from VS Code",
  "version": "0.1.0",
  "publisher": "airflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/airflow-vscode-extension"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "airflow.addServer",
        "title": "Airflow: Add Server"
      },
      {
        "command": "airflow.editServer",
        "title": "Airflow: Edit Server"
      },
      {
        "command": "airflow.deleteServer",
        "title": "Airflow: Delete Server"
      },
      {
        "command": "airflow.testConnection",
        "title": "Airflow: Test Server Connection"
      },
      {
        "command": "airflow.refreshDags",
        "title": "Airflow: Refresh DAGs"
      },
      {
        "command": "airflow.openDag",
        "title": "Airflow: Open DAG"
      },
      {
        "command": "airflow.triggerDag",
        "title": "Airflow: Trigger DAG with Config"
      },
      {
        "command": "airflow.pauseDag",
        "title": "Airflow: Pause DAG"
      },
      {
        "command": "airflow.unpauseDag",
        "title": "Airflow: Unpause DAG"
      },
      {
        "command": "airflow.deleteDag",
        "title": "Airflow: Delete DAG"
      },
      {
        "command": "airflow.clearTask",
        "title": "Airflow: Clear Task Instance(s)"
      },
      {
        "command": "airflow.viewLogs",
        "title": "Airflow: View Task Logs"
      },
      {
        "command": "airflow.openVariables",
        "title": "Airflow: Open Variables"
      },
      {
        "command": "airflow.openPools",
        "title": "Airflow: Open Pools"
      },
      {
        "command": "airflow.openConnections",
        "title": "Airflow: Open Connections"
      },
      {
        "command": "airflow.openHealth",
        "title": "Airflow: Open Health Check"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "airflow",
          "title": "Airflow",
          "icon": "resources/airflow.svg"
        }
      ]
    },
    "views": {
      "airflow": [
        {
          "id": "airflowServers",
          "name": "Servers"
        },
        {
          "id": "airflowDags",
          "name": "DAGs"
        },
        {
          "id": "airflowAdmin",
          "name": "Admin"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "airflow.editServer",
          "when": "view == airflowServers && viewItem == server"
        },
        {
          "command": "airflow.deleteServer",
          "when": "view == airflowServers && viewItem == server"
        },
        {
          "command": "airflow.testConnection",
          "when": "view == airflowServers && viewItem == server"
        },
        {
          "command": "airflow.triggerDag",
          "when": "view == airflowDags && viewItem == dag"
        },
        {
          "command": "airflow.pauseDag",
          "when": "view == airflowDags && viewItem == dag"
        },
        {
          "command": "airflow.unpauseDag",
          "when": "view == airflowDags && viewItem == dag"
        },
        {
          "command": "airflow.deleteDag",
          "when": "view == airflowDags && viewItem == dag"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "@aws-sdk/client-mwaa": "^3.400.0",
    "@aws-sdk/credential-providers": "^3.400.0"
  }
}
