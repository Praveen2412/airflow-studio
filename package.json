{
  "name": "airflow-studio",
  "displayName": "Airflow Studio",
  "description": "Comprehensive Apache Airflow and AWS MWAA management studio for VS Code",
  "version": "0.2.0",
  "publisher": "PraveenVeerapathiran",
  "icon": "resources/airflow.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Praveen2412/airflow-studio"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Data Science",
    "Visualization"
  ],
  "keywords": [
    "airflow",
    "apache-airflow",
    "mwaa",
    "aws",
    "dag",
    "workflow",
    "orchestration",
    "data-engineering",
    "etl"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Praveen2412/airflow-studio/issues"
  },
  "homepage": "https://github.com/Praveen2412/airflow-studio#readme",
  "galleryBanner": {
    "color": "#017CEE",
    "theme": "dark"
  },
  "activationEvents": [
    "onView:airflowServers"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Airflow Studio",
      "properties": {
        "airflowStudio.verboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose logging for debugging (includes all HTTP requests/responses and debug messages)"
        },
        "airflowStudio.healthCheckInterval": {
          "type": "number",
          "default": 30000,
          "description": "Health check interval in milliseconds (default: 30000 = 30 seconds)"
        },
        "airflowStudio.clientCacheTTL": {
          "type": "number",
          "default": 300000,
          "description": "API client cache TTL in milliseconds (default: 300000 = 5 minutes)"
        },
        "airflowStudio.tokenCacheTTL": {
          "type": "number",
          "default": 3000000,
          "description": "JWT token cache TTL in milliseconds (default: 3000000 = 50 minutes)"
        },
        "airflowStudio.webviewUpdateDelay": {
          "type": "number",
          "default": 500,
          "description": "Webview update delay in milliseconds (default: 500ms)"
        },
        "airflowStudio.dagCacheTTL": {
          "type": "number",
          "default": 30000,
          "description": "DAG list cache TTL in milliseconds (default: 30000 = 30 seconds)"
        },
        "airflowStudio.taskRefreshDelay": {
          "type": "number",
          "default": 1000,
          "description": "Task refresh delay after operations in milliseconds (default: 1000 = 1 second)"
        },
        "airflowStudio.httpTimeout": {
          "type": "number",
          "default": 30000,
          "description": "HTTP request timeout in milliseconds (default: 30000 = 30 seconds)"
        },
        "airflowStudio.defaultDagRunLimit": {
          "type": "number",
          "default": 25,
          "description": "Default number of DAG runs to load (default: 25)"
        },
        "airflowStudio.defaultApiLimit": {
          "type": "number",
          "default": 100,
          "description": "Default limit for API list operations (default: 100)"
        },
        "airflowStudio.logStreamInterval": {
          "type": "number",
          "default": 5000,
          "description": "Auto-refresh interval for streaming task logs in milliseconds (default: 5000 = 5 seconds)"
        }
      }
    },
    "commands": [
      {
        "command": "airflow.addServer",
        "title": "Airflow Studio: Add Server",
        "icon": "$(add)"
      },
      {
        "command": "airflow.toggleShowOnlyFavoriteServers",
        "title": "Airflow Studio: Toggle Show Only Favorite Servers",
        "icon": "$(star)"
      },
      {
        "command": "airflow.addServerPanel",
        "title": "Airflow Studio: Add Server Panel",
        "icon": "$(add)"
      },
      {
        "command": "airflow.refreshServers",
        "title": "Airflow Studio: Refresh Servers",
        "icon": "$(refresh)"
      },
      {
        "command": "airflow.toggleServerVisibility",
        "title": "Airflow Studio: Toggle Server Visibility",
        "icon": "$(eye)"
      },
      {
        "command": "airflow.toggleDagsVisibility",
        "title": "Airflow Studio: Toggle DAGs Visibility",
        "icon": "$(eye)"
      },
      {
        "command": "airflow.editServer",
        "title": "Airflow Studio: Edit Server",
        "icon": "$(edit)"
      },
      {
        "command": "airflow.toggleFavoriteServer",
        "title": "Airflow Studio: Add to Favorites",
        "icon": "$(star)"
      },
      {
        "command": "airflow.deleteServer",
        "title": "Airflow Studio: Delete Server",
        "icon": "$(trash)"
      },
      {
        "command": "airflow.toggleShowOnlyFavoriteDags",
        "title": "Airflow Studio: Toggle Show Only Favorite DAGs",
        "icon": "$(filter)"
      },
      {
        "command": "airflow.testConnection",
        "title": "Airflow Studio: Test Server Connection"
      },
      {
        "command": "airflow.openServerDetails",
        "title": "Airflow Studio: Open Server Details"
      },
      {
        "command": "airflow.refreshDags",
        "title": "Airflow Studio: Refresh DAGs",
        "icon": "$(refresh)"
      },
      {
        "command": "airflow.refreshAdmin",
        "title": "Airflow Studio: Refresh Admin",
        "icon": "$(refresh)"
      },
      {
        "command": "airflow.openDag",
        "title": "Airflow Studio: Open DAG"
      },
      {
        "command": "airflow.openDagDetails",
        "title": "Airflow Studio: Open DAG Details"
      },
      {
        "command": "airflow.triggerDag",
        "title": "Airflow Studio: Trigger DAG with Config"
      },
      {
        "command": "airflow.pauseDag",
        "title": "Airflow Studio: Pause DAG"
      },
      {
        "command": "airflow.unpauseDag",
        "title": "Airflow Studio: Unpause DAG"
      },
      {
        "command": "airflow.deleteDag",
        "title": "Airflow Studio: Delete DAG",
        "icon": "$(trash)"
      },
      {
        "command": "airflow.toggleFavoriteDag",
        "title": "Airflow Studio: Add to Favorites",
        "icon": "$(heart)"
      },
      {
        "command": "airflow.clearTask",
        "title": "Airflow Studio: Clear Task Instance(s)"
      },
      {
        "command": "airflow.viewLogs",
        "title": "Airflow Studio: View Task Logs"
      },
      {
        "command": "airflow.openVariables",
        "title": "Airflow Studio: Open Variables"
      },
      {
        "command": "airflow.openVariablesPanel",
        "title": "Airflow Studio: Open Variables Panel"
      },
      {
        "command": "airflow.openPools",
        "title": "Airflow Studio: Open Pools"
      },
      {
        "command": "airflow.openPoolsPanel",
        "title": "Airflow Studio: Open Pools Panel"
      },
      {
        "command": "airflow.openConnections",
        "title": "Airflow Studio: Open Connections"
      },
      {
        "command": "airflow.openConnectionsPanel",
        "title": "Airflow Studio: Open Connections Panel"
      },
      {
        "command": "airflow.openHealthCheck",
        "title": "Airflow Studio: Open Health Check"
      },
      {
        "command": "airflow.code.configure",
        "title": "Airflow Studio: Configure Code Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "airflow.code.pull",
        "title": "Airflow Studio: Pull from Source (Copy Only)",
        "icon": "$(cloud-download)"
      },
      {
        "command": "airflow.code.sync",
        "title": "Airflow Studio: Sync from Source (Delete Extra)",
        "icon": "$(sync)"
      },
      {
        "command": "airflow.code.push",
        "title": "Airflow Studio: Push to Source",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "airflow.code.newFile",
        "title": "Airflow Studio: New DAG File",
        "icon": "$(new-file)"
      },
      {
        "command": "airflow.code.openFile",
        "title": "Airflow Studio: Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "airflow.code.uploadFile",
        "title": "Airflow Studio: Push to Source",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "airflow.code.downloadFile",
        "title": "Airflow Studio: Pull from Source",
        "icon": "$(cloud-download)"
      },
      {
        "command": "airflow.code.deleteFile",
        "title": "Airflow Studio: Delete File",
        "icon": "$(trash)"
      },
      {
        "command": "airflow.code.renameFile",
        "title": "Airflow Studio: Rename File",
        "icon": "$(edit)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "airflowStudio",
          "title": "Airflow Studio",
          "icon": "resources/airflow.png"
        }
      ]
    },
    "views": {
      "airflowStudio": [
        {
          "id": "airflowServers",
          "name": "Servers"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "airflow.addServer",
          "when": "view == airflowServers",
          "group": "navigation@1"
        },
        {
          "command": "airflow.toggleShowOnlyFavoriteServers",
          "when": "view == airflowServers",
          "group": "navigation@2"
        },
        {
          "command": "airflow.refreshServers",
          "when": "view == airflowServers",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "airflow.editServer",
          "when": "view == airflowServers && viewItem == server",
          "group": "inline@1"
        },
        {
          "command": "airflow.toggleFavoriteServer",
          "when": "view == airflowServers && viewItem == server",
          "group": "inline@2"
        },
        {
          "command": "airflow.deleteServer",
          "when": "view == airflowServers && viewItem == server",
          "group": "inline@3"
        },
        {
          "command": "airflow.toggleShowOnlyFavoriteDags",
          "when": "view == airflowServers && viewItem == server",
          "group": "inline@4"
        },
        {
          "command": "airflow.toggleServerVisibility",
          "when": "view == airflowServers && viewItem == server"
        },
        {
          "command": "airflow.testConnection",
          "when": "view == airflowServers && viewItem == server"
        },
        {
          "command": "airflow.toggleDagsVisibility",
          "when": "view == airflowServers && viewItem == dagsFolder"
        },
        {
          "command": "airflow.refreshDags",
          "when": "view == airflowServers && viewItem == dagsFolder",
          "group": "inline@1"
        },
        {
          "command": "airflow.toggleFavoriteDag",
          "when": "view == airflowServers && viewItem == dag",
          "group": "inline@1"
        },
        {
          "command": "airflow.deleteDag",
          "when": "view == airflowServers && viewItem == dag",
          "group": "inline@2"
        },
        {
          "command": "airflow.triggerDag",
          "when": "view == airflowServers && viewItem == dag"
        },
        {
          "command": "airflow.pauseDag",
          "when": "view == airflowServers && viewItem == dag"
        },
        {
          "command": "airflow.unpauseDag",
          "when": "view == airflowServers && viewItem == dag"
        },
        {
          "command": "airflow.code.pull",
          "when": "view == airflowServers && viewItem == codeFolder",
          "group": "inline@1"
        },
        {
          "command": "airflow.code.sync",
          "when": "view == airflowServers && viewItem == codeFolder",
          "group": "inline@2"
        },
        {
          "command": "airflow.code.push",
          "when": "view == airflowServers && viewItem == codeFolder",
          "group": "inline@3"
        },
        {
          "command": "airflow.code.newFile",
          "when": "view == airflowServers && viewItem == codeFolder",
          "group": "inline@4"
        },
        {
          "command": "airflow.code.configure",
          "when": "view == airflowServers && viewItem == codeFolder",
          "group": "inline@5"
        },
        {
          "command": "airflow.code.newFile",
          "when": "view == airflowServers && viewItem == codeDirectory",
          "group": "inline@1"
        },
        {
          "command": "airflow.code.uploadFile",
          "when": "view == airflowServers && viewItem == codeFile",
          "group": "inline@1"
        },
        {
          "command": "airflow.code.downloadFile",
          "when": "view == airflowServers && viewItem == codeFile",
          "group": "inline@2"
        },
        {
          "command": "airflow.code.deleteFile",
          "when": "view == airflowServers && viewItem == codeFile",
          "group": "inline@3"
        },
        {
          "command": "airflow.code.uploadFile",
          "when": "view == airflowServers && viewItem == codeFile"
        },
        {
          "command": "airflow.code.downloadFile",
          "when": "view == airflowServers && viewItem == codeFile"
        },
        {
          "command": "airflow.code.renameFile",
          "when": "view == airflowServers && viewItem == codeFile"
        },
        {
          "command": "airflow.code.deleteFile",
          "when": "view == airflowServers && viewItem == codeFile"
        },
        {
          "command": "airflow.code.pull",
          "when": "view == airflowServers && viewItem == codeFolder"
        },
        {
          "command": "airflow.code.sync",
          "when": "view == airflowServers && viewItem == codeFolder"
        },
        {
          "command": "airflow.code.push",
          "when": "view == airflowServers && viewItem == codeFolder"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.40.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-mwaa": "^3.400.0",
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/client-sts": "^3.400.0",
    "@aws-sdk/credential-providers": "^3.400.0",
    "axios": "^1.6.0"
  }
}
